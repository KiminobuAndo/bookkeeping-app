<!-- TopAppBar -->
<header class="sticky top-0 z-50 w-full border-b border-slate-200 dark:border-slate-800 bg-white/80 dark:bg-background-dark/80 backdrop-blur-md">
  <div class="max-w-5xl mx-auto px-4 h-16 flex items-center justify-between">
    <button class="p-2 text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg">
      <span class="material-symbols-outlined">menu</span>
    </button>
    <div class="flex items-center gap-2">
      <span class="material-symbols-outlined text-secondary dark:text-primary text-3xl">account_balance_wallet</span>
      <h1 class="text-xl font-bold tracking-tight text-secondary dark:text-white">Bookkeeping Pro</h1>
    </div>
    <div class="w-10"></div>
  </div>
</header>

<main class="max-w-3xl mx-auto p-4 md:p-8 flex flex-col gap-6">
  <!-- Status & Timer Section -->
  <div class="flex items-center justify-between bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 p-4 rounded-xl shadow-sm">
    <div class="flex items-center gap-4">
      <div class="flex flex-col">
        <span class="text-xs font-semibold text-slate-500 uppercase tracking-wider">進捗</span>
        <span class="text-sm font-bold">12 / 20 問</span>
      </div>
      <div class="h-8 w-px bg-slate-200 dark:bg-slate-700"></div>
      <div class="flex flex-col">
        <span class="text-xs font-semibold text-slate-500 uppercase tracking-wider">制限時間</span>
        <span class="text-sm font-bold text-primary">残り：15秒</span>
      </div>
    </div>
    <button class="flex items-center gap-2 px-4 py-2 text-sm font-medium text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg transition-colors" disabled>
      <span>スキップ</span>
      <span class="material-symbols-outlined text-sm">fast_forward</span>
    </button>
  </div>

  <!-- Question Section -->
  <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl shadow-sm overflow-hidden">
    <div class="p-6">
      <div class="flex items-center gap-2 mb-4">
        <span class="bg-secondary/10 dark:bg-secondary/30 text-secondary dark:text-slate-200 px-3 py-1 rounded-full text-xs font-bold">問題</span>
        <div class="h-1 flex-1 bg-slate-100 dark:bg-slate-800 rounded-full overflow-hidden">
          <div class="h-full bg-secondary w-2/3"></div>
        </div>
      </div>
      <p class="text-xl md:text-2xl font-medium leading-relaxed text-slate-800 dark:text-slate-100">
        <%= @question.prompt %>
      </p>
    </div>
  </div>

  <!-- Journal Entry Section (仕訳) -->
  <%= form_with model: @answer, url: answers_path do |f| %>
    <%= f.hidden_field :question_id, value: @question.id %>

    <% if @answer.errors.any? %>
      <div class="p-4 rounded-xl bg-red-50 border border-red-200">
        <p class="text-sm font-medium text-red-800 mb-2">入力内容を確認してください</p>
        <ul class="list-disc list-inside space-y-1">
          <% @answer.errors.full_messages.each do |message| %>
            <li class="text-sm text-red-700"><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl shadow-sm p-6">
      <h3 class="text-lg font-bold text-slate-900 dark:text-slate-100 mb-6 flex items-center gap-2">
        <span class="material-symbols-outlined text-secondary dark:text-primary">edit_note</span>
        仕訳入力
      </h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 relative">
        <!-- Divider -->
        <div class="hidden md:block absolute left-1/2 top-0 bottom-0 w-px bg-slate-200 dark:bg-slate-700 -translate-x-1/2"></div>

        <!-- 借方 (Debit) -->
        <div class="space-y-4">
          <div class="flex items-center justify-between">
            <label class="flex items-center gap-2 cursor-pointer">
              <%= f.radio_button :selected_side, "debit", class: "accent-secondary" %>
              <span class="text-sm font-bold text-slate-500">借方</span>
            </label>
            <span class="text-[10px] bg-slate-100 dark:bg-slate-800 px-2 py-0.5 rounded text-slate-400">DEBIT</span>
          </div>
          <div class="flex flex-col gap-3">
            <div class="relative">
              <input class="w-full bg-slate-50 dark:bg-slate-800 border-2 border-dashed border-slate-300 dark:border-slate-700 rounded-xl p-4 text-center text-slate-400 focus:outline-none focus:border-secondary cursor-pointer" placeholder="勘定科目を選択" readonly type="text"/>
            </div>
            <div class="relative">
              <span class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">¥</span>
              <%= f.number_field :input_amount, min: 0,
                  class: "w-full bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl p-4 pl-8 text-right font-mono text-lg font-bold focus:ring-2 focus:ring-secondary/20 focus:border-secondary outline-none",
                  placeholder: "0" %>
            </div>
          </div>
        </div>

        <!-- 貸方 (Credit) -->
        <div class="space-y-4">
          <div class="flex items-center justify-between">
            <label class="flex items-center gap-2 cursor-pointer">
              <%= f.radio_button :selected_side, "credit", class: "accent-secondary" %>
              <span class="text-sm font-bold text-slate-500">貸方</span>
            </label>
            <span class="text-[10px] bg-slate-100 dark:bg-slate-800 px-2 py-0.5 rounded text-slate-400">CREDIT</span>
          </div>
          <div class="flex flex-col gap-3">
            <div class="relative">
              <input class="w-full bg-slate-50 dark:bg-slate-800 border-2 border-dashed border-slate-300 dark:border-slate-700 rounded-xl p-4 text-center text-slate-400 focus:outline-none focus:border-secondary cursor-pointer" placeholder="勘定科目を選択" readonly type="text"/>
            </div>
            <div class="relative">
              <span class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">¥</span>
              <input class="w-full bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl p-4 pl-8 text-right font-mono text-lg font-bold" type="number" min="0" placeholder="0" disabled/>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Account Selection Section (選択メニュー) -->
    <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl shadow-sm p-6 mb-12">
      <h3 class="text-sm font-bold text-slate-500 uppercase tracking-widest mb-4">選択メニュー</h3>
      <div class="flex flex-wrap gap-3">
        <button type="button" class="px-6 py-3 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl font-medium hover:border-secondary hover:text-secondary transition-all shadow-sm active:scale-95">現金</button>
        <button type="button" class="px-6 py-3 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl font-medium hover:border-secondary hover:text-secondary transition-all shadow-sm active:scale-95">売上</button>
        <button type="button" class="px-6 py-3 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl font-medium hover:border-secondary hover:text-secondary transition-all shadow-sm active:scale-95">仕入</button>
        <button type="button" class="px-6 py-3 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl font-medium hover:border-secondary hover:text-secondary transition-all shadow-sm active:scale-95">商品</button>
        <button type="button" class="px-6 py-3 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl font-medium hover:border-secondary hover:text-secondary transition-all shadow-sm active:scale-95">買掛金</button>
        <button type="button" class="px-6 py-3 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl font-medium hover:border-secondary hover:text-secondary transition-all shadow-sm active:scale-95">売掛金</button>
      </div>
    </div>

    <!-- Submission Section (fixed footer) -->
    <div class="fixed bottom-0 left-0 right-0 p-4 bg-white/90 dark:bg-background-dark/90 backdrop-blur-md border-t border-slate-200 dark:border-slate-800">
      <div class="max-w-3xl mx-auto flex gap-4">
        <%= f.submit "回答する",
            class: "flex-1 bg-secondary text-white py-4 rounded-xl font-bold text-lg hover:opacity-90 transition-opacity flex items-center justify-center gap-2 cursor-pointer" %>
      </div>
    </div>
  <% end %>
</main>

<div class="h-24"></div>

<nav class="sticky top-0 z-50 bg-white dark:bg-slate-900 border-b border-slate-200 dark:border-slate-800 px-4 py-3 flex items-center justify-between">
  <div class="flex items-center gap-2">
    <div class="bg-primary rounded-lg p-1.5 flex items-center justify-center">
      <span class="material-symbols-outlined text-white text-2xl">account_balance</span>
    </div>
    <h1 class="font-bold text-lg tracking-tight text-secondary dark:text-white">Bookkeeping</h1>
  </div>
  <div class="flex items-center gap-3">
    <span class="bg-primary/10 text-primary px-3 py-1 rounded-full text-sm font-bold border border-primary/20">
      成績
    </span>
    <%= button_to "ログアウト", destroy_user_session_path,
        method: :delete,
        class: "text-xs font-medium text-slate-500 dark:text-slate-400 hover:text-primary transition-colors cursor-pointer bg-transparent border-0 p-0" %>
  </div>
</nav>

<main class="flex-1 p-4 space-y-4 max-w-md mx-auto w-full">
  <%# コース選択セクション %>
  <section class="bg-white dark:bg-slate-900 rounded-xl shadow-sm border border-slate-200 dark:border-slate-800 p-5">
    <div class="flex items-center gap-2 mb-4">
      <span class="material-symbols-outlined text-primary">menu_book</span>
      <h2 class="text-lg font-bold">コース選択</h2>
    </div>
    <div class="space-y-4">
      <%= form_with url: start_quiz_path, method: :get, local: true do |f| %>
        <div class="relative">
          <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1 ml-1 uppercase tracking-wider">
            選択中のコース
          </label>
          <div class="relative">
            <%= f.select :course_id,
                options_from_collection_for_select(@courses, :id, :name),
                { prompt: "コースを選択してください" },
                {
                  class: "appearance-none w-full bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-3.5 pr-10 text-slate-700 dark:text-slate-200 font-medium focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all",
                  id: "course_select"
                } %>
            <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none">
              <span class="material-symbols-outlined text-slate-400">expand_more</span>
            </div>
          </div>
        </div>
        <%= f.submit "勉強スタート",
            class: "w-full bg-secondary dark:bg-primary text-white font-bold py-4 rounded-xl shadow-lg shadow-secondary/20 dark:shadow-primary/20 flex items-center justify-center gap-2 hover:opacity-90 transition-opacity active:scale-[0.98] cursor-pointer",
            disabled: @courses.empty? %>
      <% end %>
    </div>
  </section>

  <%# 同コースの他者の状況（静的ダミー） %>
  <section class="bg-white dark:bg-slate-900 rounded-xl shadow-sm border border-slate-200 dark:border-slate-800 p-5">
    <div class="flex items-center justify-between mb-4">
      <div class="flex items-center gap-2">
        <span class="material-symbols-outlined text-slate-400">groups</span>
        <h2 class="text-sm font-bold">同コースの他者の状況</h2>
      </div>
      <span class="text-[10px] font-medium text-slate-400 uppercase tracking-widest">Live Updates</span>
    </div>
    <div class="space-y-3">
      <div class="flex items-center justify-between p-2 rounded-lg bg-slate-50 dark:bg-slate-800/50">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 rounded-full bg-slate-200 dark:bg-slate-700 flex items-center justify-center overflow-hidden">
            <span class="material-symbols-outlined text-slate-400 text-sm">person</span>
          </div>
          <div>
            <p class="text-xs font-bold">ユーザー A</p>
            <p class="text-[10px] text-slate-500">2分前に完了</p>
          </div>
        </div>
        <span class="text-xs font-bold text-green-600 dark:text-green-400 bg-green-50 dark:bg-green-900/30 px-2 py-0.5 rounded">正解率 95%</span>
      </div>
      <div class="flex items-center justify-between p-2 rounded-lg border border-slate-100 dark:border-slate-800">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 rounded-full bg-slate-200 dark:bg-slate-700 flex items-center justify-center overflow-hidden">
            <span class="material-symbols-outlined text-slate-400 text-sm">person</span>
          </div>
          <div>
            <p class="text-xs font-bold">ユーザー B</p>
            <p class="text-[10px] text-slate-500">15分前に完了</p>
          </div>
        </div>
        <span class="text-xs font-bold text-green-600 dark:text-green-400 bg-green-50 dark:bg-green-900/30 px-2 py-0.5 rounded">正解率 88%</span>
      </div>
    </div>
  </section>

  <%# 直近履歴（静的ダミー） %>
  <section class="bg-white dark:bg-slate-900 rounded-xl shadow-sm border border-slate-200 dark:border-slate-800 p-5">
    <div class="flex items-center gap-2 mb-4">
      <span class="material-symbols-outlined text-slate-400">history</span>
      <h2 class="text-sm font-bold"><%= current_user.name %>さんの同コースの直近履歴</h2>
    </div>
    <div class="space-y-3">
      <div class="border-l-2 border-primary pl-4 py-1">
        <div class="flex justify-between items-start">
          <div>
            <p class="text-xs font-bold">第3章：現金過不足</p>
            <p class="text-[10px] text-slate-500">2023/10/24 14:20</p>
          </div>
          <span class="text-xs font-bold text-primary">Score: 8/10</span>
        </div>
      </div>
      <div class="border-l-2 border-slate-200 dark:border-slate-700 pl-4 py-1">
        <div class="flex justify-between items-start">
          <div>
            <p class="text-xs font-bold">第2章：仕訳のルール</p>
            <p class="text-[10px] text-slate-500">2023/10/22 09:15</p>
          </div>
          <span class="text-xs font-bold text-slate-400">Score: 10/10</span>
        </div>
      </div>
      <button class="w-full py-2 text-xs font-bold text-slate-400 hover:text-primary transition-colors">
        履歴をもっと見る
      </button>
    </div>
  </section>
</main>

<div class="h-20"></div>

<%# 下部ナビ（静的） %>
<div class="fixed bottom-0 left-0 right-0 bg-white dark:bg-slate-900 border-t border-slate-200 dark:border-slate-800 px-4 pb-6 pt-2 flex items-center justify-around max-w-md mx-auto">
  <a class="flex flex-col items-center gap-1 text-primary" href="#">
    <span class="material-symbols-outlined">home</span>
    <p class="text-[10px] font-bold">ホーム</p>
  </a>
  <a class="flex flex-col items-center gap-1 text-slate-400 hover:text-primary" href="#">
    <span class="material-symbols-outlined">auto_stories</span>
    <p class="text-[10px] font-medium">コース</p>
  </a>
  <a class="flex flex-col items-center gap-1 text-slate-400 hover:text-primary" href="#">
    <span class="material-symbols-outlined">history_edu</span>
    <p class="text-[10px] font-medium">履歴</p>
  </a>
  <a class="flex flex-col items-center gap-1 text-slate-400 hover:text-primary" href="#">
    <span class="material-symbols-outlined">settings</span>
    <p class="text-[10px] font-medium">設定</p>
  </a>
</div>

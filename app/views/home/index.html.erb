<header class="sticky top-0 z-50 w-full border-b border-slate-200 dark:border-slate-800 bg-white/80 dark:bg-background-dark/80 backdrop-blur-md">
  <div class="max-w-7xl mx-auto px-4 h-16 flex items-center justify-between">
    <div class="flex items-center gap-2">
      <span class="material-symbols-outlined text-primary text-3xl">calculate</span>
      <span class="text-xl font-bold tracking-tight text-navy-accent dark:text-slate-100">Bookkeeping Learning</span>
    </div>
    <%# 未実装のナビゲーションリンク（コース一覧・学習プラン・法人導入）は将来実装予定 %>
    <%#
    <nav class="hidden md:flex gap-8">
      <a class="text-sm font-medium hover:text-primary transition-colors" href="#">コース一覧</a>
      <a class="text-sm font-medium hover:text-primary transition-colors" href="#">学習プラン</a>
      <a class="text-sm font-medium hover:text-primary transition-colors" href="#">法人導入</a>
    </nav>
    %>
    <div class="flex items-center gap-4">
      <%= link_to "ログイン", new_user_session_path, class: "text-sm font-bold text-navy-accent dark:text-slate-300" %>
    </div>
  </div>
</header>

<main>
  <section class="relative overflow-hidden pt-16 pb-20 lg:pt-24 lg:pb-32">
    <div class="max-w-7xl mx-auto px-4 relative z-10">
      <div class="flex flex-col items-center text-center max-w-4xl mx-auto">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/10 text-primary text-xs font-bold mb-6">
          <span class="material-symbols-outlined text-sm">auto_awesome</span>
          <span>最新のAI学習エンジン搭載</span>
        </div>
        <h1 class="text-4xl md:text-6xl font-black leading-tight tracking-tight text-navy-accent dark:text-white mb-8">
          プロフェッショナルな<br/><span class="text-primary">簿記学習</span>を、あなたの手に
        </h1>
        <div class="grid grid-cols-1 md:grid-cols-3 items-center gap-8 mb-10">
          <div class="hidden md:flex flex-col items-center justify-center p-6 rounded-2xl bg-white dark:bg-slate-800 shadow-xl border border-slate-100 dark:border-slate-700">
            <span class="material-symbols-outlined text-6xl text-primary mb-4">analytics</span>
            <p class="text-sm font-bold text-slate-600 dark:text-slate-400">データ分析</p>
          </div>
          <div class="flex flex-col items-center">
            <p class="text-lg md:text-xl text-slate-600 dark:text-slate-400 leading-relaxed">
              初心者からプロを目指す方まで、効率的に簿記をマスターできる最新の学習プラットフォーム。確かな知識を、一生の力に変えましょう。
            </p>
          </div>
          <div class="hidden md:flex flex-col items-center justify-center p-6 rounded-2xl bg-white dark:bg-slate-800 shadow-xl border border-slate-100 dark:border-slate-700">
            <span class="material-symbols-outlined text-6xl text-primary mb-4">school</span>
            <p class="text-sm font-bold text-slate-600 dark:text-slate-400">体系的学習</p>
          </div>
        </div>
        <div class="flex flex-col sm:flex-row gap-4 items-center">
          <%= link_to "始める", new_user_registration_path, class: "w-full sm:w-auto px-10 py-4 bg-navy-accent dark:bg-primary text-white text-lg font-bold rounded-xl hover:opacity-90 transition-all shadow-lg hover:shadow-primary/20" %>
          <%= link_to "詳しく見る", "#features", class: "w-full sm:w-auto px-10 py-4 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 text-slate-700 dark:text-slate-300 text-lg font-bold rounded-xl hover:bg-slate-50 transition-all" %>
        </div>
      </div>
    </div>
    <div class="absolute top-1/2 left-0 -translate-y-1/2 -translate-x-1/2 w-96 h-96 bg-primary/5 rounded-full blur-3xl -z-10"></div>
    <div class="absolute bottom-0 right-0 translate-x-1/4 w-[500px] h-[500px] bg-primary/10 rounded-full blur-3xl -z-10"></div>
  </section>

  <section id="features" class="py-20 bg-white dark:bg-slate-900/50">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold text-navy-accent dark:text-white mb-4">学習のポイント</h2>
        <p class="text-slate-600 dark:text-slate-400">信頼できるカリキュラムで、確実にステップアップ。</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="p-8 rounded-2xl bg-background-light dark:bg-slate-800 border border-slate-200 dark:border-slate-700 hover:border-primary transition-colors group">
          <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center mb-6 group-hover:bg-primary group-hover:text-white transition-colors">
            <span class="material-symbols-outlined">menu_book</span>
          </div>
          <h3 class="text-xl font-bold mb-3">体系的な講義</h3>
          <p class="text-slate-600 dark:text-slate-400 leading-relaxed">
            基礎から応用まで網羅。プロの講師陣が作成した分かりやすい教材で、迷わず学習を進められます。
          </p>
        </div>
        <div class="p-8 rounded-2xl bg-background-light dark:bg-slate-800 border border-slate-200 dark:border-slate-700 hover:border-primary transition-colors group">
          <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center mb-6 group-hover:bg-primary group-hover:text-white transition-colors">
            <span class="material-symbols-outlined">edit_note</span>
          </div>
          <h3 class="text-xl font-bold mb-3">実践的な演習</h3>
          <p class="text-slate-600 dark:text-slate-400 leading-relaxed">
            本番形式のテストが充実。アウトプットを重視した設計で、試験に強い実力を養います。
          </p>
        </div>
        <div class="p-8 rounded-2xl bg-background-light dark:bg-slate-800 border border-slate-200 dark:border-slate-700 hover:border-primary transition-colors group">
          <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center mb-6 group-hover:bg-primary group-hover:text-white transition-colors">
            <span class="material-symbols-outlined">trending_up</span>
          </div>
          <h3 class="text-xl font-bold mb-3">進捗管理</h3>
          <p class="text-slate-600 dark:text-slate-400 leading-relaxed">
            グラフで学習量を確認。AIがあなたの弱点を分析し、最適な復習タイミングを提案します。
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20">
    <div class="max-w-5xl mx-auto px-4">
      <div class="rounded-3xl bg-navy-accent dark:bg-slate-800 p-8 md:p-16 text-center text-white relative overflow-hidden shadow-2xl">
        <div class="relative z-10">
          <h2 class="text-3xl md:text-4xl font-bold mb-6">今すぐ学習をスタートしましょう</h2>
          <p class="text-slate-300 mb-10 text-lg">最短ルートで合格を目指すなら。まずは無料トライアルから。</p>
          <%= link_to "始める", new_user_registration_path, class: "bg-primary hover:bg-primary/90 text-white px-12 py-4 rounded-xl text-lg font-bold transition-all transform hover:scale-105" %>
        </div>
        <div class="absolute top-0 right-0 w-64 h-64 bg-primary/20 rounded-full -translate-y-1/2 translate-x-1/2 blur-3xl"></div>
        <div class="absolute bottom-0 left-0 w-64 h-64 bg-primary/10 rounded-full translate-y-1/2 -translate-x-1/2 blur-3xl"></div>
      </div>
    </div>
  </section>
</main>

<footer class="border-t border-slate-200 dark:border-slate-800 py-12 bg-white dark:bg-background-dark">
  <div class="max-w-7xl mx-auto px-4 flex flex-col items-center">
    <div class="flex items-center gap-2 mb-8 opacity-50 grayscale">
      <span class="material-symbols-outlined text-2xl">calculate</span>
      <span class="text-lg font-bold tracking-tight">Bookkeeping Learning</span>
    </div>
    <div class="flex flex-wrap justify-center gap-x-8 gap-y-4 mb-8">
      <a class="text-sm text-slate-500 dark:text-slate-400 hover:text-primary transition-colors" href="#">利用規約</a>
      <a class="text-sm text-slate-500 dark:text-slate-400 hover:text-primary transition-colors" href="#">プライバシーポリシー</a>
      <a class="text-sm text-slate-500 dark:text-slate-400 hover:text-primary transition-colors" href="#">特定商取引法に基づく表記</a>
      <a class="text-sm text-slate-500 dark:text-slate-400 hover:text-primary transition-colors" href="#">お問い合わせ</a>
    </div>
    <p class="text-xs text-slate-400 dark:text-slate-500">
      &copy; 2024 Bookkeeping Learning App. All rights reserved.
    </p>
  </div>
</footer>

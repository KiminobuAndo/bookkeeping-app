<!-- Header -->
<header class="sticky top-0 z-10 flex items-center justify-between bg-white dark:bg-slate-900 px-4 py-3 border-b border-slate-200 dark:border-slate-800">
  <div class="flex size-10 items-center justify-center">
    <%= link_to dashboard_path, class: "text-slate-600 dark:text-slate-400" do %>
      <span class="material-symbols-outlined">close</span>
    <% end %>
  </div>
  <h1 class="text-secondary dark:text-white text-lg font-bold tracking-tight">Bookkeeping Pro</h1>
  <div class="size-10"></div>
</header>

<main class="flex-1 overflow-y-auto p-4 md:p-6 max-w-md mx-auto w-full">
  <%= render "summary_card", result: @result %>

  <% if @result.result_details.any? %>
    <div class="mb-6">
      <div class="flex items-center gap-2 mb-3">
        <span class="material-symbols-outlined text-secondary dark:text-primary text-xl">description</span>
        <h2 class="text-slate-900 dark:text-white text-lg font-bold">問題ごとの結果</h2>
      </div>
      <% @result.result_details.each_with_index do |result_detail, index| %>
        <%= render "result_detail", result_detail: result_detail, index: index %>
      <% end %>
    </div>
  <% end %>

  <%= render "action_buttons", result: @result %>
</main>

<!-- Bottom Navigation Bar -->
<nav class="fixed bottom-0 left-0 right-0 bg-white dark:bg-slate-900 border-t border-slate-200 dark:border-slate-800 px-6 pb-6 pt-2 flex justify-between items-center z-20">
  <a class="flex flex-col items-center gap-1 text-slate-400" href="#">
    <span class="material-symbols-outlined">home</span>
    <span class="text-[10px] font-medium">ホーム</span>
  </a>
  <a class="flex flex-col items-center gap-1 text-secondary dark:text-primary" href="#">
    <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1">menu_book</span>
    <span class="text-[10px] font-medium">学習</span>
  </a>
  <a class="flex flex-col items-center gap-1 text-slate-400" href="#">
    <span class="material-symbols-outlined">analytics</span>
    <span class="text-[10px] font-medium">分析</span>
  </a>
  <a class="flex flex-col items-center gap-1 text-slate-400" href="#">
    <span class="material-symbols-outlined">settings</span>
    <span class="text-[10px] font-medium">設定</span>
  </a>
</nav>

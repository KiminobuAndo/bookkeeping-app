<%# ローカル変数: result %>
<div class="flex flex-col gap-3 pb-20">
  <%= link_to start_quiz_path(course_id: result.course_id),
      class: "w-full bg-secondary dark:bg-primary hover:opacity-90 text-white font-bold py-4 rounded-xl shadow-md transition-all flex items-center justify-center gap-2" do %>
    <span class="material-symbols-outlined">refresh</span>
    もう一度挑戦する
  <% end %>

  <%= link_to dashboard_path,
      class: "w-full bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 text-slate-700 dark:text-slate-200 font-bold py-4 rounded-xl hover:bg-slate-50 dark:hover:bg-slate-800 transition-all flex items-center justify-center gap-2" do %>
    <span class="material-symbols-outlined">home</span>
    トップに戻る
  <% end %>
</div>
